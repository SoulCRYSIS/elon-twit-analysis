# Copy to .env for local dev, or set the same keys in Railway → Variables.
# Railway: mark PK / PRIVATE_KEY as secret. Use DRY_RUN=true until you are ready for live orders.
#
# Polymarket CLOB may return 403 geoblock from cloud IPs even in a "US" Railway region — they filter by
# egress IP, not your dashboard region. If you see geoblock errors, run live trading from a network they
# allow (often home/office in a permitted jurisdiction). See: https://docs.polymarket.com/developers/CLOB/geoblock

# --- Required for live trading ---
PK=
# PRIVATE_KEY=
DRY_RUN=false

# --- Paths (Railway/Fly: attach a volume and set DATA_DIR=/data) ---
# DATA_DIR=/data
# Polymarket parquet/events cache (default: DATA_DIR/polymarket). Set explicitly if you import polymarket_data alone.
# POLYMARKET_DATA_DIR=/data/polymarket

# --- Polymarket CLOB API (HTTP L2) — optional; avoids L1 create/derive if set ---
# If unset: derive existing API key first, then register (derive-first avoids 400 «Could not create api key»
# when a wallet already has a Polymarket-generated key).
# POLYMARKET_API_KEY=
# POLYMARKET_API_SECRET=
# POLYMARKET_PASSPHRASE=

# --- Wallet / chain ---
# CHAIN_ID=137
# GAMMA_URL=https://gamma-api.polymarket.com
# CLOB_URL=https://clob.polymarket.com
# CLOB_HTTP_TIMEOUT=10
#
# If the UI shows a balance but CLOB says balance 0, or orders say invalid_signature:
#
# **Funder** = the Polymarket **proxy wallet** (the main 0x “your wallet” / portfolio address shown on polymarket.com —
# NOT a “relayer signer”, NOT an internal relayer contract). Official client notes:
#   https://github.com/Polymarket/py-clob-client#start-trading-proxy-wallet
#
# **Signature type** must match how you created the account (wrong type → invalid_signature):
#   POLYMARKET_SIGNATURE_TYPE=1   Magic / email login — private key **exported from Polymarket** for that account
#   POLYMARKET_SIGNATURE_TYPE=2   MetaMask, Rabby, or other **browser wallet** linked to Polymarket (most common)
#   (omit or 0)                  Pure EOA: PK is the same address that holds funds on-chain (no Polymarket proxy)
#
# Example (browser wallet + proxy):
#   POLYMARKET_SIGNATURE_TYPE=2
#   POLYMARKET_FUNDER=0xYourProxyFromProfileDropdown

# --- Loop & retrain ---
# POLL_INTERVAL=3600
# RETRAIN_HOURS=72
# PRICE_HISTORY_HOURS=48

# --- Sizing & risk ---
# BET_USD=1
# BUY_MARKET_MAX_PRICE_DIFF=0.1   # use FOK market buy when CLOB BUY price is within this of snapshot (0–1)
# BUY_MARKET_MIN_USD=1.01           # floor for market buys (Polymarket rejects marketable BUY under ~$1)
# MAX_POSITIONS=20
# DRY_RUN_START_BALANCE=100

# --- Buy filters ---
# PRED_MIN=6
# JACKPOT_PROBA_MIN=0.01
# BUY_PRICE_MAX=0.02
# BUY_PRICE_MIN=0.001
# BRACKETS_AWAY_MIN=1.5
# BRACKETS_AWAY_MAX=6.0
# BUY_MIN_HOURS_REMAINING=24
# BUY_COOLDOWN_HOURS=4
# BUY_AGAIN_PRICE_RATIO=2

# --- Sell rules ---
# SELL_TARGET_X=4.5
# SELL_1DAY_HOURS=24

# --- Event discovery (Gamma) ---
# EVENT_SEARCH_QUERY=elon musk tweets
# EVENT_SEARCH_LIMIT=50
# EVENTS_STATUS=active
# EVENT_FETCH_SLEEP_SEC=0.2
