# Copy to .env for local dev, or set the same keys in Railway → Variables.
# Railway: mark PK / PRIVATE_KEY as secret. Use DRY_RUN=true until you are ready for live orders.

# --- Required for live trading ---
PK=
# PRIVATE_KEY=
DRY_RUN=false

# --- Paths (Railway: attach a volume and set e.g. DATA_DIR=/data) ---
# DATA_DIR=/data

# --- Wallet / chain ---
# CHAIN_ID=137
# GAMMA_URL=https://gamma-api.polymarket.com
# CLOB_URL=https://clob.polymarket.com
# CLOB_HTTP_TIMEOUT=10

# --- Loop & retrain ---
# POLL_INTERVAL=3600
# RETRAIN_HOURS=72
# PRICE_HISTORY_HOURS=48

# --- Sizing & risk ---
# BET_USD=1
# MAX_POSITIONS=20
# DRY_RUN_START_BALANCE=100

# --- Buy filters ---
# PRED_MIN=6
# JACKPOT_PROBA_MIN=0.01
# BUY_PRICE_MAX=0.02
# BUY_PRICE_MIN=0.001
# BRACKETS_AWAY_MIN=1.5
# BRACKETS_AWAY_MAX=6.0
# BUY_MIN_HOURS_REMAINING=24
# BUY_COOLDOWN_HOURS=4
# BUY_AGAIN_PRICE_RATIO=2

# --- Sell rules ---
# SELL_TARGET_X=4.5
# SELL_1DAY_HOURS=24

# --- Event discovery (Gamma) ---
# EVENT_SEARCH_QUERY=elon musk tweets
# EVENT_SEARCH_LIMIT=50
# EVENTS_STATUS=active
# EVENT_FETCH_SLEEP_SEC=0.2
